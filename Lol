MainFrame.Position = UDim2.new(0.5, -100, 0, 45)
MainFrame.Size = UDim2.new(0, 200, 0, 75)
MainFrame.BorderSizePixel = 0
MainFrame.Active = true 

UICorner.CornerRadius = UDim.new(0, 10)
